set.seed(123)
example_data <- data.frame(
age = runif(50, 5, 1000),
dead = rbinom(50, 1, 0.5),
group = sample(c("Control", "Treatment"), 50, replace = TRUE)
)
augmented <- augment_surv_data(example_data, reps = 5)
head(augmented)
View(augmented)
library(bshazard)
# Try fitting a model
fit <- safe_bshazard(Surv(age, dead) ~ group, data = example_data)
# Check attributes
attr(fit, "used_aug")     # TRUE/FALSE
attr(fit, "aug_reason")   # Reason if augmentation used
# Create a folder for diagnostics
dir.create("diagnostics", showWarnings = FALSE)
# Run diagnostic function
diagnose_augmentation(example_data, out_dir = "diagnostics", reps = 5)
km_plot <- survminer::ggsurvplot(
survfit(Surv(age, dead) ~ group, data = example_data),
data = example_data,
palette = c("black", "red"),
risk.table = FALSE
)$plot
km_plot
# Make sure you pass a compatible band_plot (if needed)
make_km_band(km_plot, band_plot = km_plot, data = example_data)
library(survival)
# ---- 1. Tiny dataset (small n triggers singular system) ----
set.seed(123)
example_small <- data.frame(
age = c(5, 10, 12, 20, 25, 30),   # very few events
dead = c(1, 0, 1, 0, 1, 0),
group = c("A", "A", "B", "B", "A", "B")
)
# ---- 2. Run safe_bshazard ----
fit_aug <- safe_bshazard(Surv(age, dead) ~ group, data = example_small)
# ---- 3. Check attributes ----
attr(fit_aug, "used_aug")    # should be TRUE
attr(fit_aug, "aug_reason")  # should contain singularity message
# ---- 4. Run diagnostics ----
# create a temporary directory to store plots
tmp_dir <- tempdir()
diagnose_augmentation(example_small, out_dir = tmp_dir, reps = 5)
# ---- 5. Check generated plots ----
list.files(tmp_dir, pattern = "km|augmented")
set.seed(123)
example_singular <- data.frame(
age   = c(1, 1, 1, 1, 1),       # all events at same time
dead  = c(1, 1, 0, 0, 0),       # very few deaths
group = c("A", "A", "B", "B", "B")
)
fit_aug <- safe_bshazard(Surv(age, dead) ~ group, data = example_singular)
attr(fit_aug, "used_aug")    # should now be TRUE
attr(fit_aug, "aug_reason")  # should contain singularity message
