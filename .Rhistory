#test augment function
#---------------------------
#Level 1: Interactive test
df <- data.frame(
age   = c(5, 10, 15),
dead  = c(1, 0, 1),
group = c("A", "A", "B")
)
set.seed(123)
out <- augment_surv_data(df, reps = 5)
nrow(out)              # should be 15 (3 × 5)
head(out)
summary(out$age)
all(out$age > 0)
#Level 2: Edge-case tests
#1 event
df1 <- data.frame(
age = c(10, 10, 10),
dead = c(1, 0, 0),
group = c("A", "A", "B")
)
augment_surv_data(df1)
#very small age
df2 <- data.frame(
age = c(0.5, 1, 1.5),
dead = c(1, 1, 0),
group = c("A", "B", "A")
)
out2 <- augment_surv_data(df2, reps = 3)
min(out2$age) > 0
#---------------------------
#Level 3: Proper unit tests
usethis::use_testthat()
usethis::use_test("augment_surv_data")
test_that("multiplication works", {
expect_equal(2 * 2, 4)
})
